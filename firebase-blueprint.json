{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data including contact and preference configurations",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "username": { "type": "string" },
        "birthDate": { "type": "string" },
        "gender": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "headerUrl": { "type": "string" },
        "twoFactorEnabled": { "type": "boolean" },
        "timezone": { "type": "string" },
        "language": { "type": "string" },
        "currency": { "type": "string" },
        "profileVisibility": { "type": "string" },
        "cookiesAccepted": { "type": "boolean" },
        "trackingEnabled": { "type": "boolean" },
        "notifyEmail": { "type": "boolean" },
        "notifySMS": { "type": "boolean" },
        "notifyPush": { "type": "boolean" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles database"
    }
  }
}
