DATABASE_URL=file:/home/z/my-project/db/custom.db

# ZAYTRIX backend security secrets (SEC-BACKEND).
# These are DEV secrets committed for local development only — REPLACE in production
# via a real secret manager (Vault, AWS SSM, Doppler, etc.) before any public deploy.
# SESSION_SECRET is used to sign/verify the `zaytrix_session` JWT cookie.
SESSION_SECRET=ZAYTRIX_DEV_SESSION_SECRET_CHANGE_IN_PRODUCTION_2024_a8f3k2j9
# ENCRYPTION_KEY is the master key for AES-256-GCM encryption of stored exchange API
# keys. It is run through crypto.scryptSync() to derive a 32-byte AES key, so the
# raw value here does not need to be exactly 32 bytes (but must be stable across
# restarts so existing ciphertexts stay decryptable).
ENCRYPTION_KEY=ZAYTRIX_DEV_ENCRYPTION_KEY_32BYTES_CHANGE_ME_2024_k9j2
# Optional: production origin for CORS. If unset, CORS allows same-origin / reflected
# origin (origin: true) — which is correct for the Vite dev proxy + Caddy gateway.
# APP_URL=https://app.zaytrix.example.com
APP_URL=http://localhost:3000

# =============================================================================
# SEC2-AUTH additions (2FA / email verification / password reset / OAuth / CSRF)
# =============================================================================

# Email (dev mode: log to console; production: real SMTP)
EMAIL_FROM=noreply@zaytrix.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_DEV_MODE=true

# Google OAuth (leave empty to disable — endpoints return "belum dikonfigurasi")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# CSRF (double-submit cookie pattern). The middleware only ENFORCES when the
# `zaytrix_csrf` cookie is present (backward compat — see security.ts).
CSRF_SECRET=ZAYTRIX_CSRF_SECRET_DEV_CHANGE_ME_2024

