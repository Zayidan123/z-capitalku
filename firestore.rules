rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default catch-all rule to deny all read/write operations by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for User Profiles
    match /profiles/{userId} {
      // Allow the authenticated owner of the profile to read and write their own profile
      allow get, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
